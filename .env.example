# Supabase
# Leave these blank for local mock mode. Once filled, the app can start using Supabase-backed repositories.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=library-files

# AI / Summary generation
# Optional for now. If absent, file summary generation falls back to a graceful placeholder mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# App behavior
# Optional override. Defaults to "auto", which means:
# - use Supabase when credentials are present
# - otherwise use local fallback repositories
DATA_MODE=auto
